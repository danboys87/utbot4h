# ── Bitget API ────────────────────────────────────────────────────────────────
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# ── Mode ──────────────────────────────────────────────────────────────────────
DRY_RUN=true

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI Analyst ────────────────────────────────────────────────────────────────
# Daftar gratis di: https://openrouter.ai
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Model gratis pilihan (uncomment salah satu):
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
# DASHBOARD_SECRET=isi_password_jika_mau_aman

# ── JSONBin (cloud state, opsional) ──────────────────────────────────────────
JSONBIN_API_KEY=
JSONBIN_BIN_ID=

# ── Log Level ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

